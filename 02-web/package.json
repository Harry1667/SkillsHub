{
  "name": "skillshub",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm -w @skillshub/web run dev",
    "build": "npm -w @skillshub/web run build",
    "start": "npm -w @skillshub/web run start",
    "lint": "npm -ws run lint --if-present",
    "typecheck": "npm -ws run typecheck --if-present",
    "db:generate": "npm -w @skillshub/web run db:generate",
    "db:migrate": "npm -w @skillshub/web run db:migrate"
  },
  "engines": {
    "node": ">=22"
  }
}
