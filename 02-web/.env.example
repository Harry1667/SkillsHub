# ─── App ───
NODE_ENV=development
APP_URL=http://localhost:3002
PORT=3002

# ─── Auth ───
# bcrypt hash of your admin password. 建議長度 ≥ 16 字。
# 產生方式：node -e "console.log(require('bcryptjs').hashSync('YOUR_PASSWORD', 12))"
ADMIN_PASSWORD_HASH=
# 隨機產生：openssl rand -base64 32
SESSION_SECRET=
# 首次啟動若留空會自動產生並 log 到 console，請記下來給 Claude Code MCP 用
API_TOKEN=

# ─── Database ───
# 相對於 packages/web/（dev）；生產在 container 裡是 /data/skills.db
DATABASE_PATH=../../data/skills.db

# ─── proxycli（所有 AI 走這） ───
PROXYCLI_GRPC_URL=cli.twloop.com:443
PROXYCLI_REST_URL=https://clip.twloop.com
PROXYCLI_TOKEN=
PROXYCLI_PROJECT=skillshub
LLM_MONTHLY_USD_CAP=5

# ─── GitHub ───
# https://github.com/settings/tokens 產生 classic PAT，scope 只要 public_repo
GITHUB_TOKEN=

# ─── Cron ───
CRON_TIMEZONE=Asia/Taipei
CRON_SCHEDULE="0 3 * * 0"
